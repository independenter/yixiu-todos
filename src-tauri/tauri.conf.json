{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yixiu-todos",
  "version": "0.1.0",
  "identifier": "com.yixiu.todos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "一修Todo — 精力占用面板",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "skipTaskbar": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Productivity",
    "shortDescription": "个人/团队待办管理 + 精力占用面板",
    "longDescription": "跨平台待办管理软件，支持优先级、时间冲突检测、精力占用面板、员工任务管理、强制录入规则与定时提醒。"
  }
}
